## Пример переменных окружения для локального запуска (без Docker)
##
## Скопируйте в .env и при необходимости измените.

# App
APP_NAME=Science Helpy API
APP_VERSION=1.0.0
DEBUG=True
HOST=0.0.0.0
PORT=8000

# Database (локальная Postgres)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=science_helpy

# Либо можно задать одним URL (приоритет зависит от вашей логики подключения)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/science_helpy

# Security
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS (пример)
# CORS_ORIGINS=["http://localhost:3000"]

# Agents / LLM
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
TAVILY_API_KEY=
